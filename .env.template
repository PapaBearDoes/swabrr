# =============================================================================
# Swabbarr — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# Sensitive values (API keys, passwords) go in Docker Secrets, NOT here.
# See api/secrets/README.md for secret file setup.
# =============================================================================

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
SWABBARR_LOG_LEVEL=INFO

# Log format: human (colorized, default) | json (structured)
SWABBARR_LOG_FORMAT=human

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# DB password is a Docker Secret — not stored here
SWABBARR_DB_HOST=swabbarr-db
SWABBARR_DB_PORT=5432
SWABBARR_DB_NAME=swabbarr
SWABBARR_DB_USER=swabbarr

# -----------------------------------------------------------------------------
# External Service URLs
# -----------------------------------------------------------------------------
# API keys for these services are Docker Secrets — not stored here
SWABBARR_TAUTULLI_URL=http://10.20.30.x:8181
SWABBARR_RADARR_URL=http://10.20.30.x:7878
SWABBARR_SONARR_URL=http://10.20.30.x:8989
SWABBARR_SONARR_ANIME_URL=http://10.20.30.x:8990
SWABBARR_SEERR_URL=http://10.20.30.x:5055

# -----------------------------------------------------------------------------
# TMDB (optional — enhances rarity and cultural value scoring)
# -----------------------------------------------------------------------------
# API key is a Docker Secret — not stored here
# Region for streaming availability lookup (ISO 3166-1 alpha-2)
SWABBARR_TMDB_REGION=US

# -----------------------------------------------------------------------------
# Scoring Schedule
# -----------------------------------------------------------------------------
# Cron expression for automated scoring runs (APScheduler format)
# Default: Weekly on Sunday at 3:00 AM
SWABBARR_SCORE_CRON=0 3 * * 0

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
SWABBARR_API_HOST=0.0.0.0
SWABBARR_API_PORT=8484

# -----------------------------------------------------------------------------
# Container Runtime
# -----------------------------------------------------------------------------
# User/Group ID for file permissions (match your host user)
PUID=1000
PGID=1000

# Timezone
TZ=America/Los_Angeles

# -----------------------------------------------------------------------------
# HTTP Client
# -----------------------------------------------------------------------------
# Timeout in seconds for external API calls
SWABBARR_HTTP_TIMEOUT=30

# Max retries for transient failures (5xx, timeouts)
SWABBARR_HTTP_RETRIES=3
