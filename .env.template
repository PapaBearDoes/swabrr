# =============================================================================
# Swabrr — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
#
# SERVICE CONNECTIONS: URLs and API keys for Tautulli, Radarr, Sonarr, Seerr,
# and TMDB are configured through the dashboard Settings page — NOT here.
# Only two Docker Secrets are needed: DB password and encryption key.
# See api/secrets/README.md for setup.
# =============================================================================

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
SWABBARR_LOG_LEVEL=INFO

# Log format: human (colorized, default) | json (structured)
SWABBARR_LOG_FORMAT=human

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# DB password is a Docker Secret — not stored here
SWABBARR_DB_HOST=swabrr-db
SWABBARR_DB_PORT=5432
SWABBARR_DB_NAME=swabrr
SWABBARR_DB_USER=swabrr

# -----------------------------------------------------------------------------
# TMDB Region (used for streaming availability lookups)
# -----------------------------------------------------------------------------
SWABBARR_TMDB_REGION=US

# -----------------------------------------------------------------------------
# Scoring Schedule
# -----------------------------------------------------------------------------
# Cron expression for automated scoring runs (APScheduler format)
# Default: Weekly on Sunday at 3:00 AM
SWABBARR_SCORE_CRON=0 3 * * 0

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
SWABBARR_API_HOST=0.0.0.0
SWABBARR_API_PORT=8484

# -----------------------------------------------------------------------------
# Container Runtime
# -----------------------------------------------------------------------------
# User/Group ID for file permissions (match your host user)
PUID=1000
PGID=1000

# Timezone
TZ=America/Los_Angeles

# -----------------------------------------------------------------------------
# HTTP Client
# -----------------------------------------------------------------------------
# Timeout in seconds for external API calls
SWABBARR_HTTP_TIMEOUT=30

# Max retries for transient failures (5xx, timeouts)
SWABBARR_HTTP_RETRIES=3
